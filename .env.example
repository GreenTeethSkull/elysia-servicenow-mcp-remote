# Required: ServiceNow instance URL
SERVICENOW_INSTANCE_URL=https://dev12345.service-now.com

# Required: ServiceNow credentials (Basic Auth)
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your-password-here

# Optional: ServiceNow API timeout in milliseconds (default: 30000)
SERVICENOW_TIMEOUT=30000

# Optional: Server configuration
PORT=3000
HOST=0.0.0.0

# Optional: CORS origins (comma-separated, * for all)
CORS_ORIGIN=*

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info
